---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Suniai',
  description = 'Holistic life coaching, mind-body work, and massage therapy with Suniai.',
} = Astro.props;

const fullTitle = title === 'Suniai' ? 'Suniai' : `${title} | Suniai`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen bg-cream text-bark">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  function initFadeIn() {
    const imgs = document.querySelectorAll<HTMLImageElement>('img:not([aria-hidden="true"])');
    if (!imgs.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.opacity = '1';
            (entry.target as HTMLElement).style.translate = 'none';
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    imgs.forEach((img) => {
      img.style.opacity = '0';
      img.style.translate = '0 42px';
      img.style.transition = 'opacity 0.7s ease, translate 0.7s ease';
      observer.observe(img);
    });
  }

  // Run on initial load and after view transitions
  initFadeIn();
  document.addEventListener('astro:page-load', initFadeIn);
</script>
