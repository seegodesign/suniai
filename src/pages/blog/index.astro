---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog"
  description="Writings on holistic living, embodiment, and the journey back to yourself — from Suniai."
>

  <section class="bg-sand-light py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-terracotta mb-4">Blog</p>
      <h1 class="font-serif text-5xl md:text-6xl text-bark mb-6">Writings</h1>
      <p class="text-lg text-bark/70 leading-relaxed">
        Reflections on the body, the mind, and the art of coming home to yourself.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-20">
    {posts.length === 0 ? (
      <p class="text-center text-bark/50">No posts yet — check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>

</Layout>
