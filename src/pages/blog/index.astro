---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog"
  description="Writings on holistic living, embodiment, and the journey back to yourself — from Suniai."
>

  <PageHero
    eyebrow="Blog"
    heading="Writings"
    subheading="Reflections on the body, the mind, and the art of coming home to yourself."
    image="https://images.unsplash.com/photo-1534109284468-ad30ffd1f41d"
    tint="bg-black/10"
  />

  <section class="max-w-6xl mx-auto px-6 py-20">
    {posts.length === 0 ? (
      <p class="text-center text-bark/50">No posts yet — check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            heroImage={post.data.heroImage}
          />
        ))}
      </div>
    )}
  </section>

</Layout>
