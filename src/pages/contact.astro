---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry } from "astro:content";

const contactEntry = await getEntry("contact", "contact");
const contact = contactEntry!.data;
const iframeId = `inline-${contact.formId}`;
const formSrc = `https://api.leadconnectorhq.com/widget/form/${contact.formId}`;
---

<Layout
  title={contact.title}
  description={contact.description}
>
  <PageHero
    eyebrow={contact.eyebrow}
    heading={contact.heading}
    subheading={contact.subheading}
    image={contact.heroImage}
  />

  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="relative" style={`min-height:${contact.formHeight}px`}>
      <div
        id={`${iframeId}-skeleton`}
        aria-hidden="true"
        class="absolute inset-0 z-10 rounded-[3px] bg-white p-6 sm:p-8 transition-opacity duration-300"
      >
        <div class="h-full w-full animate-pulse">
          <div class="h-7 w-2/3 rounded bg-rose/25"></div>
          <div class="mt-8 h-4 w-full rounded bg-sand"></div>
          <div class="mt-3 h-4 w-5/6 rounded bg-sand"></div>
          <div class="mt-8 h-11 w-full rounded bg-sand-light"></div>
          <div class="mt-4 h-11 w-full rounded bg-sand-light"></div>
          <div class="mt-4 h-11 w-full rounded bg-sand-light"></div>
          <div class="mt-8 h-24 w-full rounded bg-sand-light"></div>
          <div class="mt-8 h-11 w-44 rounded bg-rose/35"></div>
        </div>
      </div>

      <iframe
        src={formSrc}
        style="width:100%;height:100%;border:none;border-radius:3px"
        class="relative z-20 opacity-0 transition-opacity duration-300"
        id={iframeId}
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name={contact.formName}
        data-height={String(contact.formHeight)}
        data-layout-iframe-id={iframeId}
        data-form-id={contact.formId}
        title={contact.iframeTitle}
      >
      </iframe>
    </div>
    <script src="https://link.msgsndr.com/js/form_embed.js"></script>
    <script is:inline>
      (() => {
        const initFormSkeleton = () => {
          const iframe = document.querySelector('iframe[data-form-id]');
          const skeleton = document.querySelector('[id$="-skeleton"]');
          if (!(iframe instanceof HTMLIFrameElement) || !(skeleton instanceof HTMLElement)) return;
          if (iframe.dataset.skeletonBound === 'true') return;

          iframe.dataset.skeletonBound = 'true';

          const showForm = () => {
            iframe.classList.remove('opacity-0');
            skeleton.classList.add('opacity-0', 'pointer-events-none');
            window.setTimeout(() => {
              skeleton.style.display = 'none';
            }, 320);
          };

          iframe.addEventListener('load', showForm, { once: true });
          window.setTimeout(showForm, 4500);
        };

        initFormSkeleton();
        document.addEventListener('astro:page-load', initFormSkeleton);
      })();
    </script>
  </section>
</Layout>
