---
import Layout from '../layouts/Layout.astro';
import FAQItem from '../components/FAQItem.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('faq');

// Group by category, sorted by order within each category
const categoryOrder = ['Getting Started', 'Life Coaching & Somatic Work', 'Massage Therapy', 'Practical'];

const faqs = categoryOrder
  .map((category) => ({
    category,
    items: allItems
      .filter((item) => item.data.category === category)
      .sort((a, b) => a.data.order - b.data.order),
  }))
  .filter(({ items }) => items.length > 0);
---

<Layout
  title="FAQ"
  description="Answers to common questions about working with Suniai — coaching, somatic work, massage therapy, and more."
>

  <PageHero
    eyebrow="FAQ"
    heading="Common questions."
    subheading='If you don&apos;t find what you&apos;re looking for, please <a href="/contact" class="text-dark-rose hover:underline">get in touch</a>.'
  />

  <section class="max-w-3xl mx-auto px-6 py-20 space-y-14">
    {faqs.map(({ category, items }) => (
      <div>
        <h2 class="font-serif text-2xl text-bark mb-2">{category}</h2>
        <div>
          {items.map((item) => (
            <FAQItem question={item.data.question} answer={item.data.answer} />
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- CTA -->
  <div class="max-w-3xl mx-auto px-6 pb-20 text-center">
    <p class="text-bark/60 mb-5">Still have questions?</p>
    <a
      href="/contact"
      class="inline-block px-8 py-3.5 bg-dark-rose text-cream font-medium rounded-full hover:bg-bark transition-colors"
    >
      Get in Touch
    </a>
  </div>

</Layout>
