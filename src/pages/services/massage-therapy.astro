---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Massage Therapy"
  description="Therapeutic massage with Suniai — tailored bodywork from deep tissue to gentle restorative touch."
>

  <section class="bg-sand-light py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-terracotta mb-4">Services</p>
      <div class="text-4xl mb-5">🤲</div>
      <h1 class="font-serif text-5xl md:text-6xl text-bark mb-6">Massage Therapy</h1>
      <p class="text-lg text-bark/70 leading-relaxed">
        Therapeutic touch that meets your body exactly where it is.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20 grid md:grid-cols-3 gap-12">
    <div class="md:col-span-2 space-y-6 text-bark/70 leading-relaxed">
      <h2 class="font-serif text-3xl text-bark">About the massage work</h2>
      <p>
        Placeholder description — describe your massage philosophy. How do you approach the body? What makes your sessions different from a standard spa massage?
      </p>
      <p>
        Describe how sessions are tailored. Do you integrate any breath, somatic awareness, or intention-setting into the session?
      </p>

      <h3 class="font-serif text-2xl text-bark pt-4">Techniques & modalities</h3>
      <ul class="space-y-2">
        {[
          'Swedish/relaxation massage',
          'Deep tissue work',
          'Myofascial release',
          'Trigger point therapy',
          'Lymphatic drainage',
          'Restorative / nervous-system focused touch',
        ].map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-terracotta shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>

      <h3 class="font-serif text-2xl text-bark pt-4">Who is this for?</h3>
      <p>
        Placeholder — describe who benefits most. People with chronic tension? Those going through stress? Those wanting to reconnect with their body?
      </p>
    </div>

    <aside class="space-y-6">
      <div class="bg-sand rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-widest text-terracotta mb-4">Session Details</p>
        <dl class="space-y-3 text-sm text-bark/70">
          <div><dt class="font-medium text-bark">Duration</dt><dd>60 or 90 minutes</dd></div>
          <div><dt class="font-medium text-bark">Format</dt><dd>In-person only</dd></div>
          <div><dt class="font-medium text-bark">Location</dt><dd>Practice address TBC</dd></div>
          <div><dt class="font-medium text-bark">Investment</dt><dd>Placeholder pricing</dd></div>
        </dl>
      </div>
      <a
        href="/contact"
        class="block w-full py-3.5 bg-terracotta text-cream font-medium rounded-full text-center hover:bg-bark transition-colors"
      >
        Book a Session
      </a>
      <a href="/services" class="block text-center text-sm text-bark/50 hover:text-terracotta transition-colors">
        ← Back to all services
      </a>
    </aside>
  </section>

</Layout>
