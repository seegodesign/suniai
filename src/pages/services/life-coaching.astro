---
import ServicePage from '../../components/ServicePage.astro';
import { getEntry } from 'astro:content';

const service = await getEntry('services', 'life-coaching');
const { title, icon, heroImage, tagline, descriptionHeading, description1, description2, itemsHeading, items, whoIsThisFor, sessionDetails } = service.data;
---

<ServicePage
  title={title}
  icon={icon}
  heroImage={heroImage}
  tagline={tagline}
  descriptionHeading={descriptionHeading}
  description1={description1}
  description2={description2}
  itemsHeading={itemsHeading}
  items={items}
  whoIsThisFor={whoIsThisFor}
  sessionDetails={sessionDetails}
/>
