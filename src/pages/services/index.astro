---
import Layout from "../../layouts/Layout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import PageHero from "../../components/PageHero.astro";
import { getCollection, getEntry } from "astro:content";

const servicesPageEntry = await getEntry("servicesPage", "services-page");
const servicesPage = servicesPageEntry!.data;

const allServices = await getCollection("services");

// Preserve display order
const ORDER = [
  "life-coaching",
  "group-coaching",
  "massage-therapy",
  "womb-therapy",
  "online-sessions",
];
const TAGS: Record<string, string[]> = {
  "life-coaching": ["60 min", "$185", "Package available"],
  "group-coaching": ["Group", "Workshops"],
  "massage-therapy": ["In-person", "Therapeutic"],
  "womb-therapy": ["90/120 min", "$225-$285", "In-person"],
  "online-sessions": ["Online", "60 min", "$185"],
};
const publishedServices = allServices.filter((s) => !s.data.draft);
const services = ORDER.map((id) => publishedServices.find((s) => s.id === id))
  .filter(Boolean)
  .map((s) => ({
    title: s!.data.title,
    description: s!.data.description1,
    heroImage: s!.data.heroImage,
    href: `/services/${s!.id}`,
    tags: TAGS[s!.id] ?? [],
  }));
---

<Layout
  title={servicesPage.title}
  description={servicesPage.description}
>
  <!-- Hero -->
  <PageHero
    eyebrow={servicesPage.eyebrow}
    heading={servicesPage.heading}
    image={servicesPage.heroImage}
    subheading={servicesPage.subheading}
  />

  <!-- Service cards grid -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => <ServiceCard {...service} />)}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-bark text-cream py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-tangerine text-4xl mb-5">{servicesPage.ctaHeading}</h2>
      <p class="text-cream/70 mb-8 leading-relaxed">
        {servicesPage.ctaBody}
      </p>
      <a
        href={servicesPage.ctaHref}
        class="inline-block px-8 py-3.5 bg-dark-rose text-cream font-medium rounded-full hover:bg-cream hover:text-bark transition-colors"
      >
        {servicesPage.ctaLabel}
      </a>
    </div>
  </section>
</Layout>
