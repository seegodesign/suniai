---
import Layout from "../../layouts/Layout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import PageHero from "../../components/PageHero.astro";
import { getCollection } from "astro:content";

const allServices = await getCollection("services");

// Preserve display order
const ORDER = [
  "life-coaching",
  "group-coaching",
  "massage-therapy",
  "somatic-work",
  "womb-clearing",
  "online-sessions",
];
const TAGS: Record<string, string[]> = {
  "life-coaching": ["1:1", "In-person", "Online"],
  "group-coaching": ["Group", "Workshops"],
  "massage-therapy": ["In-person", "Therapeutic"],
  "somatic-work": ["1:1", "In-person", "Online"],
  "womb-clearing": ["1:1", "In-person"],
  "online-sessions": ["Online", "1:1"],
};
const services = ORDER.map((id) => allServices.find((s) => s.id === id))
  .filter(Boolean)
  .map((s) => ({
    title: s!.data.title,
    description: s!.data.description1,
    heroImage: s!.data.heroImage,
    href: `/services/${s!.id}`,
    tags: TAGS[s!.id] ?? [],
  }));
---

<Layout
  title="Services"
  description="Explore Suniai's offerings — life coaching, group workshops, somatic work, massage therapy, and online sessions."
>
  <!-- Hero -->
  <PageHero
    eyebrow="Services"
    heading="Find the support that's right for you."
    image="https://images.unsplash.com/photo-1600706843784-6f0ad251f52f?q=80&w=1228&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    subheading="Whether you're drawn to one-on-one coaching, bodywork, group practice, or something in between — there's a way to work together."
  />

  <!-- Service cards grid -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => <ServiceCard {...service} />)}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-bark text-cream py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-serif text-4xl mb-5">Not sure where to start?</h2>
      <p class="text-cream/70 mb-8 leading-relaxed">
        Reach out and we'll have a short conversation to find the best fit for
        where you are right now.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-3.5 bg-dark-rose text-cream font-medium rounded-full hover:bg-cream hover:text-bark transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
