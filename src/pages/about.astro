---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import capriPortrait from "../assets/capri6.jpg";

const aboutEntry = await getEntry("about", "about");
const about = aboutEntry!.data;
const bioParagraphs = Array.isArray(about.bioParagraphs)
  ? about.bioParagraphs.map((paragraph) => (typeof paragraph === "string" ? paragraph : paragraph?.paragraph || ""))
  : [];
const credentials = Array.isArray(about.credentials)
  ? about.credentials.map((item) => (typeof item === "string" ? item : item?.credential || ""))
  : [];
---

<Layout title={about.title} description={about.description}>
  <!-- Page hero -->
  <PageHero
    eyebrow={about.heroEyebrow}
    heading={about.heroHeading}
    subheading={about.heroSubheading}
    image={about.heroImage}
  />

  <!-- Bio section -->
  <section
    class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-5 gap-16 items-start"
  >
    <!-- Portrait -->
    <div class="md:col-span-2">
      <Image
        src={capriPortrait}
        alt="Portrait of Capri"
        class="aspect-[3/4] w-full object-cover rounded-2xl"
      />
    </div>

    <!-- Bio text -->
    <div class="md:col-span-3">
      <h2 class="font-tangerine text-5xl text-bark mb-6">
        {about.bioHeading}
      </h2>
      <div class="text-bark/70 leading-relaxed [&>p+p]:mt-4">
        {bioParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <!-- Credentials -->
      <div class="mt-10">
        <p
          class="text-xs font-semibold uppercase tracking-widest text-dark-rose mb-4"
        >
          {about.credentialsHeading}
        </p>
        <ul class="space-y-2 text-sm text-bark/70">
          {credentials.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-dark-rose shrink-0" />
              {item}
            </li>
          ))}
        </ul>
      </div>

      <a
        href={about.ctaHref}
        class="inline-block mt-10 px-8 py-3 bg-dark-rose text-cream font-medium rounded-full hover:bg-bark transition-colors"
      >
        {about.ctaLabel}
      </a>
    </div>
  </section>

  <!-- Philosophy / values -->
  <section class="bg-peaches-n-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-tangerine text-6xl text-bark text-center mb-14">
        {about.philosophyHeading}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {about.philosophyCards.map(({ value, detail }) => (
          <div class="bg-cream rounded-2xl p-6 border border-sand">
            <h3 class="font-tangerine text-4xl text-bark mb-3">{value}</h3>
            <p class="text-sm text-bark/60 leading-relaxed">{detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
