---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Suniai"
  description="Holistic life coaching, somatic mind-body work, and therapeutic massage. Return to yourself with Suniai."
>
  <!-- Hero -->
  <section
    class="relative min-h-[90vh] flex items-center justify-center overflow-hidden"
  >
    <!-- Background image -->
    <img
      src="https://images.unsplash.com/photo-1528715471579-d1bcf0ba5e83?"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <!-- tinted overlay -->
    <div class="absolute inset-0 bg-bark/30"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p
        class="text-sm font-medium tracking-[0.2em] uppercase text-terracotta mb-6"
      >
        Holistic Life Coaching · Mind-Body Work · Massage Therapy
      </p>
      <h1 class="font-serif text-5xl md:text-7xl text-cream leading-tight mb-8">
        Return to<br /><em>yourself.</em>
      </h1>
      <p
        class="text-lg md:text-xl text-cream/80 leading-relaxed max-w-xl mx-auto mb-10"
      >
        Suniai offers a nurturing space to reconnect with your body, quiet your
        mind, and step into the life you most want to live.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="px-8 py-3.5 bg-terracotta text-cream font-medium rounded-full hover:bg-cream hover:text-bark transition-colors"
        >
          Book a Session
        </a>
        <a
          href="/services"
          class="px-8 py-3.5 border border-cream/50 text-cream font-medium rounded-full hover:border-cream hover:bg-cream/10 transition-colors"
        >
          Explore Services
        </a>
      </div>
    </div>
  </section>

  <!-- Organic divider -->
  <div
    class="w-full overflow-hidden leading-[0] text-sand-light"
    aria-hidden="true"
  >
    <svg
      viewBox="0 0 1200 60"
      preserveAspectRatio="none"
      class="w-full h-12 fill-current"
    >
      <path d="M0,0 C300,60 900,60 1200,0 L1200,60 L0,60 Z"></path>
    </svg>
  </div>

  <!-- Intro / About teaser -->
  <section
    class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-16 items-center"
  >
    <div>
      <p
        class="text-xs font-semibold uppercase tracking-widest text-terracotta mb-4"
      >
        About Suniai
      </p>
      <h2 class="font-serif text-4xl md:text-5xl text-bark mb-6">
        A gentle guide on the path back to wholeness.
      </h2>
      <p class="text-bark/70 leading-relaxed mb-4">
        Suniai is a certified holistic life coach, mind-body practitioner, and
        licensed massage therapist whose work sits at the intersection of the
        somatic and the sacred — bringing the wisdom of the body into every
        conversation.
      </p>
      <p class="text-bark/70 leading-relaxed mb-8">
        Placeholder bio text — add your background, training, and philosophy
        here.
      </p>
      <a
        href="/about"
        class="inline-flex items-center gap-2 text-terracotta font-medium hover:gap-3 transition-all"
      >
        Learn more about Suniai
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
        >
      </a>
    </div>
    <!-- Portrait placeholder -->
    <div
      class="aspect-[3/4] bg-sand rounded-2xl flex items-center justify-center text-bark/30"
    >
      <img
        src="/capri.jpg"
        alt="Portrait of Capri"
        class="aspect-[3/4] w-full object-cover rounded-2xl"
      />
    </div>
  </section>

  <!-- Services strip -->
  <section class="bg-sand-light py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p
        class="text-xs font-semibold uppercase tracking-widest text-terracotta mb-3 text-center"
      >
        What I Offer
      </p>
      <h2 class="font-serif text-4xl text-bark text-center mb-14">Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          [
            {
              title: "Life Coaching",
              icon: "🌱",
              desc: "One-on-one coaching sessions to help you clarify your direction, dissolve old patterns, and build a life that truly fits.",
              href: "/services/life-coaching",
            },
            {
              title: "Somatic Work",
              icon: "🌿",
              desc: "Body-based practices to help you listen inward, release held tension, and cultivate presence in everyday life.",
              href: "/services/somatic-work",
            },
            {
              title: "Massage Therapy",
              icon: "🤲",
              desc: "Therapeutic massage tailored to your needs — from deep tissue release to gentle restorative touch.",
              href: "/services/massage-therapy",
            },
            {
              title: "Group Coaching",
              icon: "✨",
              desc: "Workshops and group containers for collective healing, shared inquiry, and community support.",
              href: "/services/group-coaching",
            },
            {
              title: "Online Sessions",
              icon: "💻",
              desc: "Coaching and mind-body sessions available virtually — wherever you are in the world.",
              href: "/services/online-sessions",
            },
          ].map(({ title, icon, desc, href }) => (
            <a
              href={href}
              class="group bg-cream rounded-2xl p-7 border border-sand hover:border-terracotta hover:shadow-md transition-all"
            >
              <div class="text-3xl mb-4">{icon}</div>
              <h3 class="font-serif text-xl text-bark mb-3 group-hover:text-terracotta transition-colors">
                {title}
              </h3>
              <p class="text-sm text-bark/60 leading-relaxed">{desc}</p>
            </a>
          ))
        }
        <a
          href="/services"
          class="group bg-terracotta rounded-2xl p-7 flex flex-col justify-end text-cream"
        >
          <h3 class="font-serif text-xl mb-3">View all services</h3>
          <span
            class="text-sm opacity-80 group-hover:opacity-100 transition-opacity flex items-center gap-2"
          >
            Explore →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Pull-quote testimonial -->
  <section class="max-w-3xl mx-auto px-6 py-24 text-center">
    <svg
      class="w-10 h-10 text-terracotta/30 mx-auto mb-6"
      fill="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        d="M14.017 21v-7.391C14.017 10.339 16.824 7.667 21 7v1.853c-2.312.552-3.983 2.1-3.983 4.459V21h-2.999zM3 21v-7.391C3 10.339 5.806 7.667 9.983 7v1.853C7.671 9.405 6 10.953 6 13.312V21H3z"
      ></path>
    </svg>
    <blockquote
      class="font-serif text-2xl md:text-3xl text-bark leading-relaxed mb-8 italic"
    >
      "Working with Suniai changed how I experience my own body. I came in
      feeling stuck and left with a new language for understanding myself."
    </blockquote>
    <p class="text-sm font-medium text-bark/50 uppercase tracking-widest">
      — Placeholder Client, Life Coaching
    </p>
    <a
      href="/testimonials"
      class="inline-block mt-8 text-sm text-terracotta font-medium hover:underline"
    >
      Read more testimonials →
    </a>
  </section>

  <!-- CTA banner -->
  <section class="bg-bark text-cream">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <h2 class="font-serif text-4xl md:text-5xl mb-6">Ready to begin?</h2>
      <p class="text-cream/70 text-lg mb-10 leading-relaxed">
        Whether you're looking for one-on-one coaching, bodywork, or a gentle
        place to start — reach out. Every journey begins with a single
        conversation.
      </p>
      <a
        href="/contact"
        class="inline-block px-10 py-4 bg-terracotta text-cream font-medium rounded-full hover:bg-cream hover:text-bark transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
