---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import capriPortrait from "../assets/capri.jpg";
import capriPortrait2 from "../assets/capri5.jpg";
import { getCollection, getEntry, render } from "astro:content";

const homeEntry = await getEntry("home", "home");
const home = homeEntry!.data;

const ORDER = [
  "life-coaching",
  "group-coaching",
  "massage-therapy",
  "womb-therapy",
  "online-sessions",
];
const allServices = await getCollection("services");
const publishedServices = allServices.filter((s) => !s.data.draft);
const homeServices = ORDER.map((id) => publishedServices.find((s) => s.id === id))
  .filter(Boolean)
  .map((s) => ({
    title: s!.data.title,
    desc: s!.data.tagline,
    href: `/services/${s!.id}`,
  }));

---

<Layout
  description="Holy Motherhood Mentor and Womb Therapist supporting women to return to their body, intuition, and inner authority."
>
  <!-- Hero -->
  <section
    class="relative min-h-[93vh] flex items-center justify-center overflow-hidden"
  >
    <!-- Background video -->
    <video
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover block"
    >
      <source src="/video/rose.mp4" type="video/mp4" />
    </video>
    <!-- tinted overlay -->
    <div class="absolute inset-0 bg-dark-rose/70"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p
        class="text-sm font-medium tracking-[0.2em] uppercase text-white mb-6 opacity-50"
      >
        {home.heroEyebrow}
      </p>
      <h1
        class="font-tangerine text-5xl md:text-8xl text-cream leading-tight mb-8"
      >
        {home.heroHeading}
      </h1>
      <p class="text-lg text-cream/80 leading-relaxed max-w-xl mx-auto mb-10">
        {home.heroBody}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={home.heroCta1Href}
          class="px-8 py-3.5 bg-white border border-cream/50 text-dark-rose font-medium rounded-full hover:bg-rose hover:text-white transition-colors"
        >
          {home.heroCta1Label}
        </a>
        <a
          href={home.heroCta2Href}
          class="px-8 py-3.5 border border-cream/50 text-cream font-medium rounded-full hover:border-cream hover:bg-cream/10 transition-colors"
        >
          {home.heroCta2Label}
        </a>
      </div>
    </div>
  </section>
  <!-- Intro / About teaser -->
  <section
    class="max-w-6xl mx-auto px-6 py-10 grid md:grid-cols-2 gap-16 items-start"
  >
    <div>
      <h2
        class="font-tangerine text-gradient-gold text-4xl md:text-5xl text-bark mb-6"
      >
        {home.aboutHeading}
      </h2>
      {home.aboutBodies.map((paragraph, i) => (
        <p class:list={[
          "text-bark/70 leading-relaxed",
          i === home.aboutBodies.length - 1 ? "mb-8" : "mb-4",
        ]}>
          {paragraph}
        </p>
      ))}
      <a
        href="/about"
        class="inline-flex items-center gap-2 text-dark-rose font-medium hover:gap-3 transition-all"
      >
        Learn more about Suniai
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
        >
      </a>
    </div>
    <!-- Portrait -->
    <div class="relative aspect-[3/4] rounded-2xl overflow-hidden m-10 md:sticky md:top-28 md:self-start">
      <Image
        src={capriPortrait}
        alt="Portrait of Capri"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-rose/50 mix-blend-lighten"></div>
    </div>
  </section>

  <!-- Services strip -->
  <section class="relative py-24 overflow-hidden">
    <img
      src="/images/sand.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-cream/60"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <h2 class="font-tangerine text-6xl text-bark mb-3 text-center lg:text-left">
        {home.servicesHeading}
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-14 lg:gap-20 items-start">
        <div class="lg:col-span-3">
          <ul>
            {
              homeServices.map(({ title, desc, href }) => (
                <li class="border-b border-sand/70 last:border-b-0">
                  <div class="py-6 pr-2">
                    <a href={href} class="group inline-block transition-colors">
                      <h3 class="font-tangerine text-4xl text-bark group-hover:text-dark-rose transition-colors">
                        {title}
                      </h3>
                    </a>
                    <p class="mt-2 text-sm text-bark/60 leading-relaxed">
                      {desc}
                    </p>
                    <a
                      href={href}
                      class="inline-flex items-center gap-2 mt-3 text-sm text-dark-rose font-medium hover:gap-3 transition-all"
                    >
                      View service
                      <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                        ><path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                      >
                    </a>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="lg:col-span-2 text-bark/75 mt-8">
          <p class="text-md leading-relaxed mb-6">
            Each offering is designed to meet you where you are. Some days you may
            need gentle bodywork, some seasons call for deeper womb healing, and
            other moments ask for clear, grounded mentorship.
          </p>
          <p class="text-md leading-relaxed mb-6">
            This work is not one-size-fits-all. We listen to what your body and life
            are asking for, then choose the most supportive path for this chapter.
          </p>
          <p class="text-md leading-relaxed mb-8">
            If you are unsure where to begin, we can start with a conversation and
            find the right fit together.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 text-dark-rose font-medium hover:gap-3 transition-all"
          >
            Get support that fits your season
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull-quote testimonial slider -->
  <!-- <section class="max-w-3xl mx-auto px-6 py-24 text-center">
    <div id="quote-slider" class="grid mb-8">
      {
        testimonialSlides.map(({ data, Content }, i) => (
