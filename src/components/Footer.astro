---
import { getEntry } from "astro:content";

const siteEntry = await getEntry("site", "site");
const site = siteEntry!.data;
---

<footer class="bg-bark text-cream/80">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
      <!-- Brand column -->
      <div>
        <p class="font-tangerine text-6xl text-cream mb-3">{site.brandName}</p>
        <p class="text-sm leading-relaxed text-cream/60">
          {site.footerDescription}
        </p>
      </div>

      <!-- Nav links -->
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-widest text-cream/40 mb-4"
        >
          Navigation
        </p>
        <ul class="space-y-2">
          {site.footerLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="text-sm text-cream/70 hover:text-dark-rose transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-widest text-cream/40 mb-4"
        >
          {site.footerHeading}
        </p>
        <a
          href={`mailto:${site.footerEmail}`}
          class="text-sm text-cream/70 hover:text-dark-rose transition-colors"
        >
          {site.footerEmail}
        </a>
        <p class="mt-4 text-sm text-cream/60">
          {site.footerNote}
        </p>
        <a
          href={site.footerCtaHref}
          class="inline-block mt-5 px-6 py-2.5 border border-dark-rose text-dark-rose text-sm font-medium rounded-full hover:bg-dark-rose hover:text-cream transition-colors"
        >
          {site.footerCtaLabel}
        </a>
      </div>
    </div>

    <!-- Divider + legal -->
    <div
      class="border-t border-cream/10 pt-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-cream/30"
    >
      <p>&copy; {new Date().getFullYear()} {site.brandName}. All rights reserved.</p>
      <p>{site.footerCredential}</p>
      <p>
        {site.footerCreditText}{' '}
        <a href={site.footerCreditHref} target="_blank" rel="noopener noreferrer">
          Seego Design
        </a>
      </p>
    </div>
  </div>
</footer>
