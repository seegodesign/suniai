---
import Layout from '../layouts/Layout.astro';

interface Props {
  title: string;
  icon: string;
  tagline: string;
  descriptionHeading: string;
  description1: string;
  description2: string;
  itemsHeading: string;
  items: string[];
  whoIsThisFor: string;
  sessionDetails: { label: string; value: string }[];
  ctaLabel?: string;
  heroImage?: string;
}

const {
  title,
  icon,
  tagline,
  descriptionHeading,
  description1,
  description2,
  itemsHeading,
  items,
  whoIsThisFor,
  sessionDetails,
  ctaLabel = 'Book a Session',
  heroImage,
} = Astro.props;
---

<Layout title={title} description={tagline}>

  <section class="relative py-24 overflow-hidden">
    {heroImage ? (
      <>
        <img
          src={heroImage}
          alt=""
          aria-hidden="true"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/50"></div>
      </>
    ) : (
      <div class="absolute inset-0 bg-sand-light"></div>
    )}
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class:list={['text-xs font-semibold uppercase tracking-widest mb-4', heroImage ? 'text-dark-rose' : 'text-dark-rose']}>Services</p>
      <div class="text-4xl mb-5">{icon}</div>
      <h1 class:list={['font-serif text-5xl md:text-6xl mb-6', heroImage ? 'text-cream' : 'text-bark']}>{title}</h1>
      <p class:list={['text-lg leading-relaxed', heroImage ? 'text-cream/80' : 'text-bark/70']}>{tagline}</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20 grid md:grid-cols-3 gap-12">
    <div class="md:col-span-2 space-y-6 text-bark/70 leading-relaxed">
      <h2 class="font-serif text-3xl text-bark">{descriptionHeading}</h2>
      <p>{description1}</p>
      <p>{description2}</p>

      <h3 class="font-serif text-2xl text-bark pt-4">{itemsHeading}</h3>
      <ul class="space-y-2">
        {items.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-dark-rose shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>

      <h3 class="font-serif text-2xl text-bark pt-4">Who is this for?</h3>
      <p>{whoIsThisFor}</p>
    </div>

    <aside class="space-y-6">
      <div class="bg-sand rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-widest text-dark-rose mb-4">Session Details</p>
        <dl class="space-y-3 text-sm text-bark/70">
          {sessionDetails.map(({ label, value }) => (
            <div>
              <dt class="font-medium text-bark">{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <a
        href="/contact"
        class="block w-full py-3.5 bg-dark-rose text-cream font-medium rounded-full text-center hover:bg-bark transition-colors"
      >
        {ctaLabel}
      </a>
      <a href="/services" class="block text-center text-sm text-bark/50 hover:text-dark-rose transition-colors">
        ← Back to all services
      </a>
    </aside>
  </section>

</Layout>
