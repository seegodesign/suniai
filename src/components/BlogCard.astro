---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, slug, tags = [], heroImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group bg-cream rounded-2xl border border-sand hover:border-dark-rose hover:shadow-md transition-all overflow-hidden flex flex-col"
>
  <!-- Hero image or placeholder -->
  {heroImage ? (
    <img
      src={heroImage}
      alt={title}
      class="aspect-[16/9] w-full object-cover"
    />
  ) : (
    <div class="aspect-[16/9] bg-sand flex items-center justify-center text-bark/20">
      <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
    </div>
  )}

  <div class="p-6 flex flex-col flex-1">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.map((tag) => (
          <span class="px-2.5 py-0.5 text-xs rounded-full bg-sand text-bark/60">{tag}</span>
        ))}
      </div>
    )}
    <h3 class="font-serif text-xl text-bark mb-2 group-hover:text-dark-rose transition-colors leading-snug">
      {title}
    </h3>
    <p class="text-sm text-bark/60 leading-relaxed flex-1 mb-4">{description}</p>
    <p class="text-xs text-bark/40 font-medium">{formattedDate}</p>
  </div>
</a>
