---
interface Props {
  title: string;
  description: string;
  heroImage?: string;
  href: string;
  tags?: string[];
}

const { title, description, heroImage, href, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group bg-cream rounded-2xl overflow-hidden border border-sand hover:border-dark-rose hover:shadow-md transition-all flex flex-col"
>
  {heroImage ? (
    <div class="h-36 overflow-hidden">
      <img
        src={`${heroImage}?auto=format&fit=crop&w=600&h=288&q=70`}
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  ) : null}
  <div class="p-7 flex flex-col flex-1">
  <h3 class="font-serif text-xl text-bark mb-3 group-hover:text-dark-rose transition-colors">{title}</h3>
  <p class="text-sm text-bark/60 leading-relaxed flex-1">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-5">
      {tags.map((tag) => (
        <span class="px-3 py-0.5 text-xs rounded-full bg-sand text-bark/60">{tag}</span>
      ))}
    </div>
  )}
  <div class="mt-6 flex items-center gap-1.5 text-sm text-dark-rose font-medium opacity-0 group-hover:opacity-100 transition-opacity">
    Learn more
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
    </svg>
  </div>
  </div>
</a>
